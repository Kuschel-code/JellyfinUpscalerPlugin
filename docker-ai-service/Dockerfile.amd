# ============================================
# AI Upscaler Service - AMD GPU (ROCm) Version
# ============================================
# Build: docker build -f Dockerfile.amd -t kuscheltier/jellyfin-ai-upscaler:amd .
# Run: docker run --device=/dev/kfd --device=/dev/dri --group-add video -p 5000:5000 kuscheltier/jellyfin-ai-upscaler:amd

# ROCm 6.2 + PyTorch 2.3.0 — verified tag on Docker Hub
# Note: onnxruntime-rocm is deprecated after v1.23 (ROCm EP removed).
# GPU inference works via ROCm + ONNX Runtime ≤1.22.x; CPU fallback otherwise.
FROM rocm/pytorch:rocm6.2_ubuntu22.04_py3.10_pytorch_release_2.3.0

# Build-time metadata — pass via: --build-arg APP_VERSION=1.6.1.15 --build-arg APP_COMMIT=$(git rev-parse --short HEAD)
ARG APP_VERSION=1.8.1
ARG APP_COMMIT=unknown
ENV APP_VERSION=${APP_VERSION} \
    APP_COMMIT=${APP_COMMIT}

LABEL org.opencontainers.image.title="Jellyfin AI Upscaler (AMD ROCm)" \
      org.opencontainers.image.description="AI Upscaler Service with AMD ROCm 6.2 GPU Acceleration (RDNA3/RDNA2)" \
      org.opencontainers.image.vendor="Kuschel-code" \
      org.opencontainers.image.source="https://github.com/Kuschel-code/JellyfinUpscalerPlugin" \
      org.opencontainers.image.documentation="https://github.com/Kuschel-code/JellyfinUpscalerPlugin/blob/main/docker-ai-service/README.md" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.version="${APP_VERSION}" \
      org.opencontainers.image.revision="${APP_COMMIT}"

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV USE_GPU=true
# HSA_OVERRIDE_GFX_VERSION: Set this at runtime for YOUR specific GPU if needed.
# Example: HSA_OVERRIDE_GFX_VERSION=11.0.0 for RX 7900 (gfx1100)
# Do NOT set a default — it breaks GPUs that aren't gfx1100.
# ENV HSA_OVERRIDE_GFX_VERSION=11.0.0
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies for OpenCV
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    libgomp1 \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy requirements first for layer caching
COPY requirements-amd.txt requirements.txt

# Install Python dependencies, then the ROCm ONNX Runtime.
# onnxruntime-rocm ≤1.22.x is the last version with the ROCm EP (removed after v1.23).
#
# IMPORTANT (FIX-2): onnxruntime-rocm PROVIDES the `onnxruntime` module itself, so
# plain `onnxruntime` must NOT be present alongside it — otherwise the plain build
# (which reports AzureExecutionProvider/CPU) shadows the ROCm one and
# ROCMExecutionProvider never appears. That was the real cause of the CPU-only AMD
# image: the 2026-05-29 build log shows the rocm wheel installing fine as
# 1.22.2.post1, yet the runtime reported ['AzureExecutionProvider','CPUExecutionProvider']
# because plain onnxruntime (pulled by requirements) won. requirements-amd.txt no
# longer lists it; we also uninstall any pre-baked copy, then force-install the rocm
# build as the sole provider. The `|| pip install onnxruntime` tail remains only as a
# genuine wheel-unavailable safety net (a visible CPU image, never a silent one).
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip && \
    pip install -r requirements.txt && \
    { pip uninstall -y onnxruntime onnxruntime-gpu || true; } && \
    { pip install --force-reinstall "onnxruntime-rocm<=1.22.99" || pip install onnxruntime; }

# Build-time provider visibility (issue #69 lesson): make the result VISIBLE so a
# CPU-only AMD image is never published unnoticed. ROCMExecutionProvider present =
# real GPU acceleration; missing = the wheel was genuinely unavailable and we fell
# back to CPU (a valid degraded mode for AMD, unlike the hard-fail NVIDIA/Intel paths).
RUN python3 -c "import onnxruntime as ort; p = ort.get_available_providers(); print('ONNX providers:', p); print('OK: ROCMExecutionProvider present') if 'ROCMExecutionProvider' in p else print('WARNING: ROCMExecutionProvider MISSING - AMD image will run inference on CPU. Build continues (CPU is a valid fallback).')"

# Copy application code
COPY app/ ./app/
COPY static/ ./static/
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Create non-root user for running the service
# Add to video group for /dev/kfd and /dev/dri GPU access
RUN groupadd -r appuser && useradd -r -g appuser -d /app -s /sbin/nologin appuser && \
    usermod -aG video appuser 2>/dev/null || true && \
    usermod -aG render appuser 2>/dev/null || true

# Create directories for models and cache
RUN mkdir -p /app/models /app/cache /app/config && \
    chown -R appuser:appuser /app

# Expose API port
EXPOSE 5000

# Run as non-root user
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:5000/health || exit 1

# Run the application via entrypoint
ENTRYPOINT ["/entrypoint.sh"]
CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "5000"]
