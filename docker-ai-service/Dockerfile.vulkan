# Vulkan GPU Dockerfile for AI Upscaler Service
# For AMD pre-RDNA2 (RX 5700, etc.), Intel iGPUs, or any Vulkan-capable GPU
# Uses ncnn framework with Vulkan compute shaders for super-resolution

FROM python:3.12-slim-bookworm

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV DEBIAN_FRONTEND=noninteractive
ENV USE_GPU=true
ENV VULKAN_BACKEND=true

# Build-time metadata — pass via: --build-arg APP_VERSION=1.6.1.13 --build-arg APP_COMMIT=$(git rev-parse --short HEAD)
ARG APP_VERSION=1.6.1.13
ARG APP_COMMIT=unknown
ENV APP_VERSION=${APP_VERSION} \
    APP_COMMIT=${APP_COMMIT}

LABEL org.opencontainers.image.title="Jellyfin AI Upscaler (Vulkan/ncnn)" \
      org.opencontainers.image.description="AI Upscaler Service with Vulkan (ncnn) for AMD pre-RDNA2, Intel iGPU, any Vulkan-capable GPU" \
      org.opencontainers.image.vendor="Kuschel-code" \
      org.opencontainers.image.source="https://github.com/Kuschel-code/JellyfinUpscalerPlugin" \
      org.opencontainers.image.documentation="https://github.com/Kuschel-code/JellyfinUpscalerPlugin/blob/main/docker-ai-service/README.md" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.version="${APP_VERSION}" \
      org.opencontainers.image.revision="${APP_COMMIT}"

WORKDIR /app

# Install system dependencies: Vulkan SDK + Mesa drivers + OpenCV deps + build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Vulkan runtime, ICD loaders, and development headers
    libvulkan1 \
    libvulkan-dev \
    vulkan-tools \
    mesa-vulkan-drivers \
    # Vulkan shader compiler (required by ncnn build)
    glslang-tools \
    # Mesa for AMD RADV + Intel ANV Vulkan drivers
    libgl1-mesa-dri \
    # OpenCV dependencies
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    # Build tools for ncnn compilation from source
    cmake \
    build-essential \
    ninja-build \
    git \
    # Utilities
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements-vulkan.txt ./requirements.txt

# Upgrade pip and install build tools (BuildKit cache speeds rebuilds of this + next RUN)
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip setuptools wheel

# Install core Python dependencies from requirements file
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

# Install ncnn-vulkan — try pre-built wheel first, then build from source
# Note: "ncnn-vulkan" is not a real PyPI package; the correct package is "ncnn"
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install "realsr-ncnn-vulkan-python>=2.0.0,<3.0" 2>/dev/null || \
    pip install "ncnn>=1.0.20250503,<2.0" 2>/dev/null || \
    (echo "Building ncnn from source with Vulkan support..." && \
     pip install pybind11 && \
     git clone --depth 1 --branch 20250503 --single-branch https://github.com/Tencent/ncnn.git /tmp/ncnn && \
     cd /tmp/ncnn && mkdir build && cd build && \
     cmake -G Ninja \
       -DCMAKE_BUILD_TYPE=Release \
       -DNCNN_VULKAN=ON \
       -DNCNN_BUILD_EXAMPLES=OFF \
       -DNCNN_BUILD_TOOLS=ON \
       -DNCNN_BUILD_BENCHMARK=OFF \
       -DNCNN_PYTHON=ON \
       .. && \
     ninja -j$(nproc) && ninja install && \
     cd /tmp/ncnn/python && pip install . && \
     rm -rf /tmp/ncnn) || \
    (echo "ERROR: ncnn-vulkan could not be installed — Vulkan models will be unavailable" && exit 1)

# Copy application code
COPY app/ ./app/
COPY static/ ./static/
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Create non-root user for running the service
# Add to render + video groups for Vulkan GPU device access (/dev/dri/renderD*)
RUN groupadd -r appuser && useradd -r -g appuser -d /app -s /sbin/nologin appuser && \
    usermod -aG render appuser 2>/dev/null || true && \
    usermod -aG video appuser 2>/dev/null || true

# Create directories for models and cache
RUN mkdir -p /app/models /app/cache && \
    chown -R appuser:appuser /app

# Create Vulkan ICD directory for runtime GPU detection
RUN mkdir -p /etc/vulkan/icd.d

# Expose API port
EXPOSE 5000

# Run as non-root user
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:5000/health || exit 1

# Run the application via entrypoint
ENTRYPOINT ["/entrypoint.sh"]
CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "5000"]
